{
  "name": "adrianlopez-ia-blog",
  "private": true,
  "version": "0.1.0",
  "description": "Adrián López Ibáñez Blog - Modern fullstack monorepo with Astro, Hono, and AI agents",
  "author": "Adrián López Ibáñez",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "clean": "turbo clean && powershell -Command \"Remove-Item -Recurse -Force node_modules, **/.turbo, **/dist, .next, **/build\" -ErrorAction SilentlyContinue",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:studio": "turbo db:studio",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "cross-env": "^10.1.0",
    "lefthook": "^1.9.0",
    "stylelint-config-standard": "^40.0.0",
    "turbo": "^2.8.12",
    "typescript": "^5.7.0"
  }
}
