---
const year = new Date().getFullYear();
---

<footer style="border-top: 1px solid var(--color-border); background-color: var(--color-footer-bg);">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <span class="text-xl font-bold">
          <span class="gradient-text">Adrian Lopez</span>
        </span>
        <p class="mt-2 max-w-xs text-sm" style="color: var(--color-text-secondary);">
          Full-stack developer & AI enthusiast building the future of the web.
        </p>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-wide" style="color: var(--color-text-muted);">
          Navigation
        </h3>
        <ul class="mt-4 space-y-2">
          <li><a href="/" class="text-sm transition-colors hover:text-brand-500 dark:hover:text-white" style="color: var(--color-text-secondary);">Home</a></li>
          <li><a href="/blog" class="text-sm transition-colors hover:text-brand-500 dark:hover:text-white" style="color: var(--color-text-secondary);">Blog</a></li>
          <li><a href="/examples" class="text-sm transition-colors hover:text-brand-500 dark:hover:text-white" style="color: var(--color-text-secondary);">Examples</a></li>
          <li><a href="/about" class="text-sm transition-colors hover:text-brand-500 dark:hover:text-white" style="color: var(--color-text-secondary);">About</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-wide" style="color: var(--color-text-muted);">
          Connect
        </h3>
        <div class="mt-4 flex gap-4">
          <a
            href="https://github.com/adrianlopez-ia"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg p-2.5 transition-colors"
            style="color: var(--color-text-secondary); background-color: var(--color-overlay);"
            aria-label="GitHub"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/adrian-lopez-iba%C3%B1ez/"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg p-2.5 transition-colors"
            style="color: var(--color-text-secondary); background-color: var(--color-overlay);"
            aria-label="LinkedIn"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 text-center text-sm" style="border-top: 1px solid var(--color-border); color: var(--color-text-muted);">
      <p>&copy; {year} Adrian Lopez. Built with Astro, Hono & AI.</p>
    </div>
  </div>
</footer>
