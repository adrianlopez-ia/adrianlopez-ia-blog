---
const year = new Date().getFullYear();
const links = [
  { href: 'https://github.com/adrianlopez', label: 'GitHub', icon: 'github' },
  { href: 'https://twitter.com/adrianlopez', label: 'Twitter', icon: 'twitter' },
  { href: 'https://linkedin.com/in/adrianlopez', label: 'LinkedIn', icon: 'linkedin' },
];
---

<footer class="border-t border-white/5 bg-surface-950/50">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <span class="text-xl font-bold">
          <span class="gradient-text">Adrian Lopez</span>
        </span>
        <p class="mt-2 max-w-xs text-sm text-surface-200">
          Full-stack developer & AI enthusiast building the future of the web.
        </p>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-wide text-surface-200">
          Navigation
        </h3>
        <ul class="mt-4 space-y-2">
          <li><a href="/" class="text-sm text-surface-200 transition-colors hover:text-white">Home</a></li>
          <li><a href="/blog" class="text-sm text-surface-200 transition-colors hover:text-white">Blog</a></li>
          <li><a href="/examples" class="text-sm text-surface-200 transition-colors hover:text-white">Examples</a></li>
          <li><a href="/about" class="text-sm text-surface-200 transition-colors hover:text-white">About</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-wide text-surface-200">
          Connect
        </h3>
        <div class="mt-4 flex gap-4">
          {links.map(({ href, label }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg bg-white/5 p-2 text-surface-200 transition-colors hover:bg-white/10 hover:text-white"
              aria-label={label}
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-12 border-t border-white/5 pt-8 text-center text-sm text-surface-200">
      <p>&copy; {year} Adrian Lopez. Built with Astro, Hono & AI.</p>
    </div>
  </div>
</footer>
