---
import { UserMenu } from '@components/auth/UserMenu';
import { IconButton } from '@components/ui/IconButton';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/apps', label: 'Apps' },
  { href: '/examples', label: 'Examples' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 z-50 w-full border-b backdrop-blur-xl transition-all duration-300"
  style="border-color: var(--color-border-subtle); background-color: var(--color-header-bg);"
  id="main-header"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="group flex items-center gap-2">
      <span class="text-2xl font-bold">
        <span class="gradient-text">AL</span>
      </span>
      <span class="hidden font-display text-sm font-medium tracking-wide sm:block" style="color: var(--color-text-secondary);">
        Adrián López Ibáñez
      </span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'relative text-sm font-medium transition-colors duration-200',
            currentPath === href
              ? 'text-brand-500 dark:text-brand-400'
              : 'hover:text-brand-500 dark:hover:text-white',
          ]}
          style={currentPath !== href ? `color: var(--color-text-secondary)` : undefined}
        >
          {label}
          {currentPath === href && (
            <span class="absolute -bottom-1 left-0 h-0.5 w-full rounded-full bg-brand-500 dark:bg-brand-400" />
          )}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <div class="flex h-9 w-9 items-center justify-center">
        <UserMenu client:load />
      </div>

      <IconButton
        id="theme-toggle"
        variant="ghost"
        size="md"
        aria-label="Toggle dark mode"
      >
        <svg class="dark:hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <svg class="hidden dark:block h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
      </IconButton>

      <IconButton
        id="mobile-menu-btn"
        variant="ghost"
        size="md"
        aria-label="Toggle menu"
        class="md:hidden"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </IconButton>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden" style="border-top: 1px solid var(--color-border-subtle);">
    <div class="space-y-1 px-4 py-4">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'block rounded-lg px-3 py-2 text-sm font-medium transition-colors',
            currentPath === href
              ? 'bg-brand-500/10 text-brand-500 dark:text-brand-400'
              : 'hover:text-brand-500 dark:hover:text-white',
          ]}
          style={currentPath !== href ? `color: var(--color-text-secondary)` : undefined}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
