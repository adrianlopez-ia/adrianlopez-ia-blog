---
const features = [
  {
    icon: '⚡',
    title: 'Blazing Fast',
    description:
      'Zero JavaScript by default with Astro 5 islands architecture. 100/100 Lighthouse scores.',
  },
  {
    icon: '🤖',
    title: 'AI-Powered',
    description:
      'Integrated chatbots and AI agents using Vercel AI SDK and LangChain with multiple providers.',
  },
  {
    icon: '🎨',
    title: 'Modern Design',
    description:
      'Parallax effects, smooth scroll, and animations powered by GSAP and Tailwind CSS v4.',
  },
  {
    icon: '🔧',
    title: 'Multi-Framework',
    description:
      'Examples in React, Vue, Svelte, SolidJS, and vanilla Web Components -- all in one place.',
  },
  {
    icon: '📦',
    title: 'Monorepo',
    description:
      'Turborepo + pnpm workspaces with shared types, UI components, and database layer.',
  },
  {
    icon: '🛡️',
    title: 'Type-Safe',
    description:
      'End-to-end TypeScript with Zod validation from database schemas to API responses.',
  },
];
---

<section class="relative py-32" id="features">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="feature-title font-display text-4xl font-bold tracking-tight opacity-0 sm:text-5xl">
        Built with the <span class="gradient-text">Latest Tech</span>
      </h2>
      <p class="feature-subtitle mx-auto mt-4 max-w-2xl text-lg text-surface-200 opacity-0">
        Every piece of this blog is crafted with 2026's most cutting-edge tools and patterns.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature, i) => (
        <div
          class="feature-card group rounded-2xl border border-white/5 bg-white/[0.02] p-8 opacity-0 transition-all duration-300 hover:border-brand-500/30 hover:bg-white/[0.04]"
          data-delay={i * 0.1}
        >
          <span class="text-4xl">{feature.icon}</span>
          <h3 class="mt-4 font-display text-xl font-semibold">{feature.title}</h3>
          <p class="mt-2 text-sm text-surface-200">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.feature-title', {
    opacity: 1,
    y: 0,
    duration: 0.8,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#features',
      start: 'top 70%',
    },
  });

  gsap.set('.feature-title', { y: 30 });

  gsap.to('.feature-subtitle', {
    opacity: 1,
    y: 0,
    duration: 0.8,
    delay: 0.2,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#features',
      start: 'top 70%',
    },
  });

  gsap.set('.feature-subtitle', { y: 20 });

  document.querySelectorAll<HTMLElement>('.feature-card').forEach((card) => {
    const delay = parseFloat(card.dataset.delay ?? '0');

    gsap.to(card, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      delay,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: card,
        start: 'top 85%',
      },
    });

    gsap.set(card, { y: 40 });
  });
</script>
