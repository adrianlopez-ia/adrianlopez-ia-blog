---

---

<section class="relative overflow-hidden py-32" id="cta">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-brand-500/5 to-transparent" />

  <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="cta-title font-display text-4xl font-bold tracking-tight opacity-0 sm:text-5xl lg:text-6xl">
      Ready to <span class="gradient-text">Explore</span>?
    </h2>

    <p class="cta-text mx-auto mt-6 max-w-2xl text-lg opacity-0" style="color: var(--color-text-secondary);"
      Dive into articles about modern web development, AI integrations, and
      live examples with different frameworks and technologies.
    </p>

    <div class="cta-buttons mt-10 flex flex-wrap items-center justify-center gap-4 opacity-0">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-8 py-4 text-base font-semibold text-white transition-all duration-300 hover:bg-brand-600 hover:shadow-xl hover:shadow-brand-500/25"
      >
        Start Reading
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="/examples"
        class="inline-flex items-center gap-2 rounded-full px-8 py-4 text-base font-semibold transition-all duration-300"
        style="border: 1px solid var(--color-border); background-color: var(--color-overlay); color: var(--color-text);"
      >
        View Examples
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const cta = document.getElementById('cta');
  if (cta) {
    gsap.to('.cta-title', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: { trigger: cta, start: 'top 70%' },
    });
    gsap.set('.cta-title', { y: 30 });

    gsap.to('.cta-text', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      delay: 0.2,
      ease: 'power3.out',
      scrollTrigger: { trigger: cta, start: 'top 70%' },
    });
    gsap.set('.cta-text', { y: 20 });

    gsap.to('.cta-buttons', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      delay: 0.4,
      ease: 'power3.out',
      scrollTrigger: { trigger: cta, start: 'top 60%' },
    });
    gsap.set('.cta-buttons', { y: 20 });
  }
</script>
