---

---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden" id="hero">
  <!-- Parallax background layers -->
  <div class="absolute inset-0 z-0" data-speed="0.3">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-900/20 via-surface-950 to-surface-950" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--color-brand-500)_0%,_transparent_50%)] opacity-20" />
  </div>

  <div class="absolute inset-0 z-[1]" data-speed="0.5">
    <div class="stars absolute inset-0" />
  </div>

  <div class="absolute inset-0 z-[2]" data-speed="0.7">
    <div class="absolute left-1/4 top-1/4 h-64 w-64 rounded-full bg-brand-500/5 blur-3xl" />
    <div class="absolute right-1/3 bottom-1/3 h-96 w-96 rounded-full bg-brand-400/5 blur-3xl" />
  </div>

  <!-- Main content -->
  <div class="relative z-10 mx-auto max-w-5xl px-4 text-center">
    <div class="hero-badge mb-8 inline-flex items-center gap-2 rounded-full border border-brand-500/20 bg-brand-500/5 px-4 py-2 text-sm text-brand-400 opacity-0">
      <span class="h-2 w-2 animate-pulse rounded-full bg-brand-400" />
      Full-Stack Developer & AI Enthusiast
    </div>

    <h1 class="hero-title font-display text-5xl font-bold leading-tight tracking-tight sm:text-7xl lg:text-8xl">
      <span class="hero-line block opacity-0">Building the</span>
      <span class="hero-line block opacity-0">
        <span class="gradient-text">Future</span> of the
      </span>
      <span class="hero-line block opacity-0">Web with AI</span>
    </h1>

    <p class="hero-subtitle mx-auto mt-8 max-w-2xl text-lg text-surface-200 opacity-0 sm:text-xl">
      Exploring modern web development, artificial intelligence, and cutting-edge
      technologies. From parallax experiences to AI-powered applications.
    </p>

    <div class="hero-cta mt-10 flex flex-wrap items-center justify-center gap-4 opacity-0">
      <a
        href="/blog"
        class="group relative inline-flex items-center gap-2 overflow-hidden rounded-full bg-brand-500 px-8 py-3 text-sm font-semibold text-white transition-all duration-300 hover:bg-brand-600 hover:shadow-lg hover:shadow-brand-500/25"
      >
        Read the Blog
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="/examples"
        class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-8 py-3 text-sm font-semibold text-white transition-all duration-300 hover:border-white/20 hover:bg-white/10"
      >
        Explore Examples
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2 opacity-0" id="scroll-indicator">
    <div class="flex flex-col items-center gap-2">
      <span class="text-xs text-surface-200">Scroll to explore</span>
      <div class="h-10 w-6 rounded-full border-2 border-surface-200/30">
        <div class="mx-auto mt-2 h-2 w-1 animate-bounce rounded-full bg-brand-400" />
      </div>
    </div>
  </div>
</section>

<style>
  .stars {
    background-image:
      radial-gradient(2px 2px at 20px 30px, rgba(255,255,255,0.3), transparent),
      radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.2), transparent),
      radial-gradient(1px 1px at 90px 40px, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 130px 80px, rgba(255,255,255,0.2), transparent),
      radial-gradient(2px 2px at 160px 30px, rgba(255,255,255,0.3), transparent);
    background-size: 200px 100px;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({ delay: 0.5 });

  tl.to('.hero-badge', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' })
    .to('.hero-line', { opacity: 1, y: 0, duration: 0.6, stagger: 0.15, ease: 'power3.out' }, '-=0.4')
    .to('.hero-subtitle', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.3')
    .to('.hero-cta', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.4')
    .to('#scroll-indicator', { opacity: 1, duration: 1, ease: 'power2.out' }, '-=0.2');

  gsap.set('.hero-badge, .hero-line, .hero-subtitle, .hero-cta', { y: 30 });

  // Parallax layers
  document.querySelectorAll<HTMLElement>('[data-speed]').forEach((el) => {
    const speed = parseFloat(el.dataset.speed ?? '0.5');
    gsap.to(el, {
      yPercent: -30 * speed,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      },
    });
  });

  // Fade out hero on scroll
  gsap.to('#hero > .relative', {
    opacity: 0,
    y: -50,
    scrollTrigger: {
      trigger: '#hero',
      start: '20% top',
      end: '60% top',
      scrub: 1,
    },
  });
</script>
