---
interface PostData {
  title: string;
  slug: string;
  excerpt?: string;
  publishedAt?: Date;
  readingTime?: number;
  tags?: string[];
  coverImage?: string;
}

interface Props {
  posts: PostData[];
  title?: string;
}

const { posts, title } = Astro.props;
---

<section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  {title && (
    <h2 class="mb-8 font-display text-3xl font-bold tracking-tight">{title}</h2>
  )}

  {posts.length === 0 ? (
    <p class="text-center text-surface-200">No posts found.</p>
  ) : (
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <PostCard {...post} />
      ))}
    </div>
  )}
</section>
