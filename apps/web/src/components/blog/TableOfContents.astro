---
interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="text-sm" aria-label="Table of contents">
    <h2 class="mb-4 font-display text-xs font-semibold uppercase tracking-wide text-surface-200">
      On this page
    </h2>
    <ul class="space-y-2">
      {filteredHeadings.map((heading) => (
        <li class:list={[heading.depth === 3 && 'ml-4']}>
          <a
            href={`#${heading.slug}`}
            class="block text-surface-200 transition-colors hover:text-brand-400"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
