---
import { Badge } from '@components/ui/Badge';
import { Button } from '@components/ui/Button';
import BaseLayout from '@layouts/BaseLayout.astro';

const apps = [
  {
    title: 'House Bot',
    description:
      'Bot that searches for housing cooperatives in Madrid, analyzes opportunities with AI, and fills out forms automatically.',
    href: '/apps/house-bot',
    tech: ['Python', 'Gemini AI', 'Telegram', 'Playwright'],
    github: 'https://github.com/adrianlopez-ia/house-bot',
    status: 'live' as const,
    icon: '🏠',
  },
  {
    title: 'Invest Bot',
    description:
      'Investment analysis bot with AI. Monitors markets and generates automatic reports.',
    href: '#',
    tech: ['Python', 'AI', 'Finance'],
    github: 'https://github.com/adrianlopez-ia/invest-bot',
    status: 'coming-soon' as const,
    icon: '📈',
  },
];
---

<BaseLayout title="Apps" description="Applications and tools I have built. Automation bots, dashboards, and more.">
  <div class="mx-auto max-w-7xl px-4 pt-32 pb-16 sm:px-6 lg:px-8">
    <header class="mb-12 text-center">
      <h1 class="font-display text-5xl font-bold tracking-tight sm:text-6xl">
        My <span class="gradient-text">Apps</span>
      </h1>
      <p class="mt-4 text-lg" style="color: var(--color-text-secondary);">
        Tools and bots I have built to automate daily tasks.
      </p>
    </header>

    <div class="grid gap-8 sm:grid-cols-2">
      {apps.map((app) => {
        const isLive = app.status === 'live';
        return (
          <div
            class="group relative overflow-hidden rounded-2xl p-8 transition-all duration-300 themed-card"
          >
            <div class="flex items-start justify-between">
              <span class="text-4xl">{app.icon}</span>
              <Badge variant={isLive ? 'success' : 'warning'} size="sm">
                <span class={`badge-dot ${isLive ? 'animate-pulse' : ''}`} />
                {isLive ? 'Live' : 'Coming Soon'}
              </Badge>
            </div>

            <h2 class="mt-4 font-display text-2xl font-bold transition-colors group-hover:text-brand-500 dark:group-hover:text-brand-400">
              {app.title}
            </h2>
            <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              {app.description}
            </p>

            <div class="mt-4 flex flex-wrap gap-2">
              {app.tech.map((t) => (
                <Badge variant="default" size="sm">{t}</Badge>
              ))}
            </div>

            <div class="mt-6 flex items-center gap-4">
              {isLive && (
                <Button variant="primary" size="sm" href={app.href}>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                  Open App
                </Button>
              )}
              <Button variant="secondary" size="sm" href={app.github} target="_blank" rel="noopener noreferrer">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
                GitHub
              </Button>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</BaseLayout>
