---
import PostList from '@components/blog/PostList.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getAllTags, getPostsByTag, getPublishedPosts } from '@lib/content';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = getAllTags(posts);

  return tags.map(({ name }) => ({
    params: { tag: name.toLowerCase() },
    props: { tagName: name },
  }));
}

const { tag } = Astro.params;
const { tagName } = Astro.props;
const posts = await getPostsByTag(tag);
const allPosts = await getPublishedPosts();
const allTags = getAllTags(allPosts);

const postData = posts.map((post) => ({
  title: post.data.title,
  slug: post.id,
  excerpt: post.data.description,
  publishedAt: post.data.publishedAt,
  readingTime: post.data.readingTime,
  tags: post.data.tags,
  coverImage: post.data.coverImage,
}));
---

<BaseLayout title={`${tagName} posts`} description={`Articles tagged with ${tagName}.`}>
  <div class="mx-auto max-w-7xl px-4 pt-32 pb-16 sm:px-6 lg:px-8">
    <header class="mb-12 text-center">
      <h1 class="font-display text-5xl font-bold tracking-tight sm:text-6xl">
        <span class="gradient-text">{tagName}</span>
      </h1>
      <p class="mt-4 text-lg" style="color: var(--color-text-secondary);">
        {posts.length} {posts.length === 1 ? 'article' : 'articles'} tagged with {tagName}.
      </p>
    </header>

    <div class="mb-12 flex flex-wrap justify-center gap-2">
      <a
        href="/blog"
        class="rounded-full px-4 py-1.5 text-sm font-medium transition-colors hover:text-brand-500 dark:hover:text-brand-400"
        style="border: 1px solid var(--color-border); color: var(--color-text-secondary);"
      >
        All ({allPosts.length})
      </a>
      {allTags.map(({ name, count }) => (
        <a
          href={`/blog/tag/${name.toLowerCase()}`}
          class:list={[
            'rounded-full px-4 py-1.5 text-sm font-medium transition-colors',
            name.toLowerCase() === tag
              ? 'bg-brand-500/10 text-brand-600 dark:text-brand-400'
              : 'hover:text-brand-500 dark:hover:text-brand-400',
          ]}
          style={name.toLowerCase() === tag
            ? undefined
            : 'border: 1px solid var(--color-border); color: var(--color-text-secondary);'
          }
        >
          {name} ({count})
        </a>
      ))}
    </div>

    <PostList posts={postData} />
  </div>
</BaseLayout>
