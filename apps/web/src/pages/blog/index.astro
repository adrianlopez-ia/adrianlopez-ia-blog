---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostList from '@components/blog/PostList.astro';
import { getPublishedPosts, getAllTags } from '@lib/content';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);

const postData = posts.map((post) => ({
  title: post.data.title,
  slug: post.id,
  excerpt: post.data.description,
  publishedAt: post.data.publishedAt,
  readingTime: post.data.readingTime,
  tags: post.data.tags,
  coverImage: post.data.coverImage,
}));
---

<BaseLayout title="Blog" description="Articles about modern web development, AI, and cutting-edge technologies.">
  <div class="mx-auto max-w-7xl px-4 pt-32 pb-16 sm:px-6 lg:px-8">
    <header class="mb-12 text-center">
      <h1 class="font-display text-5xl font-bold tracking-tight sm:text-6xl">
        The <span class="gradient-text">Blog</span>
      </h1>
      <p class="mt-4 text-lg text-surface-200">
        Thoughts on modern web development, AI, and the technologies shaping our future.
      </p>
    </header>

    {tags.length > 0 && (
      <div class="mb-12 flex flex-wrap justify-center gap-2">
        <a
          href="/blog"
          class="rounded-full bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-400 transition-colors hover:bg-brand-500/20"
        >
          All ({posts.length})
        </a>
        {tags.map(({ name, count }) => (
          <a
            href={`/blog/tag/${name.toLowerCase()}`}
            class="rounded-full border border-white/5 px-4 py-1.5 text-sm font-medium text-surface-200 transition-colors hover:border-brand-500/30 hover:text-brand-400"
          >
            {name} ({count})
          </a>
        ))}
      </div>
    )}

    <PostList posts={postData} />
  </div>
</BaseLayout>
