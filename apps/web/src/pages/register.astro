---
import { RegisterForm } from '@components/auth/RegisterForm';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Registrarse" description="Crea una cuenta para acceder al area privada y herramientas exclusivas.">
  <div class="mx-auto flex min-h-[calc(100vh-200px)] max-w-md items-center px-4 sm:px-6">
    <div class="w-full rounded-2xl p-8 themed-card">
      <div class="mb-8 text-center">
        <h1 class="font-display text-3xl font-bold tracking-tight">
          Crear <span class="gradient-text">cuenta</span>
        </h1>
        <p class="mt-2 text-sm" style="color: var(--color-text-secondary);">
          Registrate para acceder a herramientas exclusivas
        </p>
      </div>
      <RegisterForm client:load />
    </div>
  </div>
</BaseLayout>
