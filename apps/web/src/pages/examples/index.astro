---
import BaseLayout from '@layouts/BaseLayout.astro';

const examples = [
  {
    title: 'LangChain AI Agent',
    description:
      'Advanced AI agent using LangChain, with a multi-provider pool (OpenRouter, Groc & Gemini) for high availability.',
    href: '/examples/langchain-bot',
    tech: ['LangChain', 'OpenRouter', 'AI Pool'],
    color: 'blue-500',
  },
  {
    title: 'React AI Chatbot',
    description:
      'Interactive chatbot with automatic triple failover. Uses OpenRouter first, falls back to Groc or Gemini if needed.',
    href: '/examples/react-chatbot',
    tech: ['React', 'Pool', 'Triple Failover'],
    color: 'brand-400',
  },
  {
    title: 'Vue Conversational Agent',
    description: 'Conversational AI agent with multi-model support via our smart triple AI pool.',
    href: '/examples/vue-agent',
    tech: ['Vue 3', 'OpenRouter', 'Groc', 'Gemini'],
    color: 'green-400',
  },
  {
    title: 'Svelte Interactive Widget',
    description: 'Lightweight widget with reliable AI connectivity via triple failover logic.',
    href: '/examples/svelte-widget',
    tech: ['Svelte 5', 'Triple Pool'],
    color: 'orange-400',
  },
  {
    title: 'SolidJS Dashboard',
    description: 'Real-time metrics dashboard powered by a resilient triple AI provider stack.',
    href: '/examples/solid-dashboard',
    tech: ['SolidJS', 'AI Stack'],
    color: 'blue-400',
  },
  {
    title: 'Vanilla Web Components Bot',
    description: 'Native Web Component bot connected to our fault-tolerant triple AI backend.',
    href: '/examples/vanilla-bot',
    tech: ['Web Components', 'Pool'],
    color: 'yellow-400',
  },
];
---

<BaseLayout title="Examples" description="Interactive examples and demos with different web frameworks and AI technologies.">
  <div class="mx-auto max-w-7xl px-4 pt-32 pb-16 sm:px-6 lg:px-8">
    <header class="mb-12 text-center">
      <h1 class="font-display text-5xl font-bold tracking-tight sm:text-6xl">
        Interactive <span class="gradient-text">Examples</span>
      </h1>
      <p class="mt-4 text-lg" style="color: var(--color-text-secondary);">
        Live demos built with different frameworks and AI technologies.
      </p>
    </header>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {examples.map((example) => (
        <a
          href={example.href}
          class="group relative overflow-hidden rounded-2xl p-8 transition-all duration-300 themed-card"
        >
          <h2 class="font-display text-xl font-bold transition-colors group-hover:text-brand-500 dark:group-hover:text-brand-400">
            {example.title}
          </h2>
          <p class="mt-2 text-sm" style="color: var(--color-text-secondary);">{example.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {example.tech.map((t) => (
              <span class="rounded-full px-2 py-0.5 text-xs" style="background-color: var(--color-overlay); color: var(--color-text-muted);">
                {t}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
