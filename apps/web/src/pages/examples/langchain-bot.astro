---
import ChatWidget from '@components/ai/ChatWidget';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="LangChain AI Agent" description="Interactive AI agent built with LangChain and OpenRouter.">
  <div class="mx-auto max-w-3xl px-4 pt-32 pb-16 sm:px-6 lg:px-8">
    <header class="mb-8">
      <a href="/examples" class="text-sm text-brand-500 dark:text-brand-400 hover:underline">&larr; Back to Examples</a>
      <h1 class="mt-4 font-display text-4xl font-bold tracking-tight">
        LangChain <span class="gradient-text">AI Agent</span>
      </h1>
      <p class="mt-2" style="color: var(--color-text-secondary);">
        An advanced AI agent using LangChain and a smart **AI Pool**. It uses OpenRouter by default and automatically fails over to Groc if limits are reached.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="rounded-full bg-blue-500/10 px-3 py-1 text-xs font-medium text-blue-600 dark:text-blue-400">LangChain</span>
        <span class="rounded-full bg-blue-500/10 px-3 py-1 text-xs font-medium text-blue-600 dark:text-blue-400">AI Pool</span>
        <span class="rounded-full bg-blue-500/10 px-3 py-1 text-xs font-medium text-blue-600 dark:text-blue-400">Groc Failover</span>
      </div>
    </header>

    <div class="themed-card rounded-2xl p-4 mb-8">
      <div class="flex items-center gap-2 mb-4">
        <div class="h-2 w-2 rounded-full bg-blue-500 animate-pulse"></div>
        <span class="text-xs font-medium uppercase tracking-wider text-blue-500">LangChain Mode Active</span>
      </div>
      <ChatWidget client:load useLangChain={true} />
    </div>

    <div class="mt-8 rounded-xl p-6 themed-card">
      <h2 class="font-display text-lg font-semibold">How it works</h2>
      <ul class="mt-3 space-y-2 text-sm" style="color: var(--color-text-secondary);">
        <li>- Backend powered by <code class="text-blue-500">@langchain/openai</code> configured for OpenRouter</li>
        <li>- Uses <code class="text-blue-500">HumanMessage</code> and <code class="text-blue-500">SystemMessage</code> for structured conversation</li>
        <li>- Real-time streaming using LangChain's <code class="text-blue-500">.stream()</code> method</li>
        <li>- Model: <code class="text-blue-500">nvidia/llama-3.1-nemotron-70b-instruct:free</code></li>
      </ul>
    </div>
  </div>
</BaseLayout>
