---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Vanilla Web Components Bot" description="AI bot built with native Web Components and zero dependencies.">
  <div class="mx-auto max-w-3xl px-4 pt-32 pb-16 sm:px-6 lg:px-8">
    <header class="mb-8">
      <a href="/examples" class="text-sm text-brand-500 dark:text-brand-400 hover:underline">&larr; Back to Examples</a>
      <h1 class="mt-4 font-display text-4xl font-bold tracking-tight">
        Vanilla <span class="gradient-text">Web Components</span> Bot
      </h1>
      <p class="mt-2" style="color: var(--color-text-secondary);">
        An AI bot built with native Web Components, Shadow DOM, and zero framework dependencies.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="rounded-full bg-yellow-500/10 px-3 py-1 text-xs font-medium text-yellow-600 dark:text-yellow-400">Web Components</span>
        <span class="rounded-full bg-yellow-500/10 px-3 py-1 text-xs font-medium text-yellow-600 dark:text-yellow-400">Shadow DOM</span>
        <span class="rounded-full bg-yellow-500/10 px-3 py-1 text-xs font-medium text-yellow-600 dark:text-yellow-400">Fetch API</span>
      </div>
    </header>

    <chat-bot></chat-bot>

    <div class="mt-8 rounded-xl p-6 themed-card">
      <h2 class="font-display text-lg font-semibold">How it works</h2>
      <ul class="mt-3 space-y-2 text-sm" style="color: var(--color-text-secondary);">
        <li>- Native <code class="text-yellow-600 dark:text-yellow-400">customElements.define()</code> -- no framework</li>
        <li>- Shadow DOM for encapsulated styles</li>
        <li>- <code class="text-yellow-600 dark:text-yellow-400">fetch()</code> API for communication</li>
        <li>- Zero dependencies, runs in any browser</li>
      </ul>
    </div>
  </div>
</BaseLayout>

<script>
  class ChatBot extends HTMLElement {
    private shadow: ShadowRoot;
    private messages: Array<{ role: string; content: string }> = [];

    constructor() {
      super();
      this.shadow = this.attachShadow({ mode: 'open' });
      this.render();
    }

    private render() {
      this.shadow.innerHTML = `
        <style>
          :host {
            display: block;
            border: 1px solid var(--color-border, rgba(255,255,255,0.1));
            border-radius: 1rem;
            background: var(--color-card-bg, rgba(255,255,255,0.02));
            overflow: hidden;
          }
          .header {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--color-border-subtle, rgba(255,255,255,0.05));
          }
          .header h3 { font-size: 0.875rem; font-weight: 600; color: var(--color-text, white); margin: 0; }
          .header p { font-size: 0.75rem; color: var(--color-text-muted, #9ca3af); margin: 0.25rem 0 0; }
          .messages {
            height: 350px;
            overflow-y: auto;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
          }
          .empty {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            text-align: center;
            color: var(--color-text-muted, #6b7280);
            font-size: 0.875rem;
          }
          .msg {
            max-width: 80%;
            padding: 0.5rem 1rem;
            border-radius: 1rem;
            font-size: 0.875rem;
          }
          .msg.user {
            align-self: flex-end;
            background: #eab308;
            color: black;
          }
          .msg.assistant {
            align-self: flex-start;
            background: var(--color-overlay, rgba(255,255,255,0.05));
            color: var(--color-text-secondary, #d1d5db);
          }
          .input-area {
            padding: 1rem;
            border-top: 1px solid var(--color-border-subtle, rgba(255,255,255,0.05));
            display: flex;
            gap: 0.5rem;
          }
          input {
            flex: 1;
            padding: 0.5rem 1rem;
            border-radius: 0.75rem;
            border: 1px solid var(--color-border, rgba(255,255,255,0.1));
            background: var(--color-overlay, rgba(255,255,255,0.05));
            color: var(--color-text, white);
            font-size: 0.875rem;
            outline: none;
          }
          input:focus { border-color: rgba(234,179,8,0.5); }
          button {
            padding: 0.5rem 1rem;
            border-radius: 0.75rem;
            background: #eab308;
            color: black;
            font-size: 0.875rem;
            font-weight: 500;
            border: none;
            cursor: pointer;
          }
          button:hover { background: #ca8a04; }
        </style>
        <div class="header">
          <h3>Vanilla Web Components Bot</h3>
          <p>Zero dependencies, pure browser APIs</p>
        </div>
        <div class="messages" id="messages">
          <div class="empty">Send a message to start</div>
        </div>
        <form class="input-area" id="form">
          <input type="text" id="input" placeholder="Type a message..." />
          <button type="submit">Send</button>
        </form>
      `;

      this.shadow.getElementById('form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        this.handleSend();
      });
    }

    private handleSend() {
      const input = this.shadow.getElementById('input') as HTMLInputElement;
      const text = input.value.trim();
      if (!text) return;

      this.messages.push({ role: 'user', content: text });
      input.value = '';

      setTimeout(() => {
        this.messages.push({
          role: 'assistant',
          content: `Echo: "${text}". This is a vanilla Web Components demo -- connect an API for real responses!`,
        });
        this.updateMessages();
      }, 500);

      this.updateMessages();
    }

    private updateMessages() {
      const container = this.shadow.getElementById('messages');
      if (!container) return;

      container.innerHTML = this.messages
        .map((m) => `<div class="msg ${m.role}">${m.content}</div>`)
        .join('');

      container.scrollTop = container.scrollHeight;
    }
  }

  customElements.define('chat-bot', ChatBot);
</script>
