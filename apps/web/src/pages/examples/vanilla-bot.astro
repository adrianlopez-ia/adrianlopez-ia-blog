---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Vanilla Web Components Bot" description="AI bot built with native Web Components and zero dependencies.">
  <div class="mx-auto max-w-3xl px-4 pt-32 pb-16 sm:px-6 lg:px-8">
    <header class="mb-8">
      <a href="/examples" class="text-sm text-brand-500 dark:text-brand-400 hover:underline">&larr; Back to Examples</a>
      <h1 class="mt-4 font-display text-4xl font-bold tracking-tight">
        Vanilla <span class="gradient-text">Web Components</span> Bot
      </h1>
      <p class="mt-2" style="color: var(--color-text-secondary);">
        An AI bot built with native Web Components, Shadow DOM, and streaming responses from OpenRouter (Nvidia).
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="rounded-full bg-yellow-500/10 px-3 py-1 text-xs font-medium text-yellow-600 dark:text-yellow-400">Web Components</span>
        <span class="rounded-full bg-yellow-500/10 px-3 py-1 text-xs font-medium text-yellow-600 dark:text-yellow-400">Shadow DOM</span>
        <span class="rounded-full bg-brand-500/10 px-3 py-1 text-xs font-medium text-brand-500 dark:text-brand-400">OpenRouter (Nvidia)</span>
      </div>
    </header>

    <div class="relative rounded-2xl themed-card overflow-hidden">
      <chat-bot></chat-bot>

      <div id="auth-disclaimer" class="hidden absolute inset-0 z-10 flex items-center justify-center bg-black/60 backdrop-blur-sm p-6 text-center">
        <div class="max-w-xs rounded-2xl border border-brand-500/30 bg-gray-900/90 p-6 shadow-2xl">
          <div class="mb-4 text-3xl">🔒</div>
          <h4 class="mb-2 font-semibold text-white">Restricted Access</h4>
          <p class="mb-6 text-xs text-gray-400">
            This demo uses our private **AI Pool**. You need to sign in to interact with the models.
          </p>
          <a 
            href="/login" 
            class="inline-block w-full rounded-xl bg-brand-500 py-2.5 text-sm font-medium text-white transition-all hover:bg-brand-600 hover:scale-[1.02] active:scale-95"
          >
            Sign In
          </a>
        </div>
      </div>
    </div>

    <div class="mt-8 rounded-xl p-6 themed-card">
      <h2 class="font-display text-lg font-semibold">How it works</h2>
      <ul class="mt-3 space-y-2 text-sm" style="color: var(--color-text-secondary);">
        <li>- Native <code class="text-yellow-600 dark:text-yellow-400">customElements.define()</code> -- no framework</li>
        <li>- Shadow DOM for encapsulated styles</li>
        <li>- <code class="text-brand-500 dark:text-brand-400">ReadableStream</code> for real-time AI token streaming</li>
        <li>- Connects to <code class="text-brand-500 dark:text-brand-400">/api/ai/chat</code> with Nvidia Llama 3.1</li>
      </ul>
    </div>
  </div>
</BaseLayout>

<script>
  import { getToken } from '@lib/api-client';

  // Show disclaimer if not logged in
  if (!getToken()) {
    document.getElementById('auth-disclaimer')?.classList.remove('hidden');
  }

  class ChatBot extends HTMLElement {
    private shadow: ShadowRoot;
    private messages: Array<{ role: string; content: string }> = [];
    private isLoading = false;

    constructor() {
      super();
      this.shadow = this.attachShadow({ mode: 'open' });
      this.render();
    }

    private render() {
      this.shadow.innerHTML = `
        <style>
          :host {
            display: block;
            border: 1px solid var(--color-border, rgba(255,255,255,0.1));
            border-radius: 1rem;
            background: var(--color-card-bg, rgba(255,255,255,0.02));
            overflow: hidden;
          }
          .header {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--color-border-subtle, rgba(255,255,255,0.05));
          }
          .header h3 { font-size: 0.875rem; font-weight: 600; color: var(--color-text, white); margin: 0; }
          .header p { font-size: 0.75rem; color: var(--color-text-muted, #9ca3af); margin: 0.25rem 0 0; }
          .messages {
            height: 350px;
            overflow-y: auto;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
          }
          .empty {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            text-align: center;
            color: var(--color-text-muted, #6b7280);
            font-size: 0.875rem;
          }
          .msg {
            max-width: 80%;
            padding: 0.5rem 1rem;
            border-radius: 1rem;
            font-size: 0.875rem;
            white-space: pre-wrap;
          }
          .msg.user {
            align-self: flex-end;
            background: var(--color-brand, #7c3aed);
            color: white;
          }
          .msg.assistant {
            align-self: flex-start;
            background: var(--color-overlay, rgba(255,255,255,0.05));
            color: var(--color-text-secondary, #d1d5db);
          }
          .input-area {
            padding: 1rem;
            border-top: 1px solid var(--color-border-subtle, rgba(255,255,255,0.05));
            display: flex;
            gap: 0.5rem;
          }
          input {
            flex: 1;
            padding: 0.5rem 1rem;
            border-radius: 0.75rem;
            border: 1px solid var(--color-border, rgba(255,255,255,0.1));
            background: var(--color-overlay, rgba(255,255,255,0.05));
            color: var(--color-text, white);
            font-size: 0.875rem;
            outline: none;
          }
          input:focus { border-color: var(--color-brand, #7c3aed); }
          button {
            padding: 0.5rem 1rem;
            border-radius: 0.75rem;
            background: var(--color-brand, #7c3aed);
            color: white;
            font-size: 0.875rem;
            font-weight: 500;
            border: none;
            cursor: pointer;
          }
          button:disabled { opacity: 0.5; cursor: not-allowed; }
        </style>
        <div class="header">
          <h3>Vanilla AI Bot</h3>
          <p>Powered by OpenRouter (Nvidia Llama 3.1)</p>
        </div>
        <div class="messages" id="messages">
          <div class="empty">Send a message to start</div>
        </div>
        <form class="input-area" id="form">
          <input type="text" id="input" placeholder="Type a message..." />
          <button type="submit" id="submit-btn">Send</button>
        </form>
      `;

      this.shadow.getElementById('form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        this.handleSend();
      });
    }

    private async handleSend() {
      if (this.isLoading) return;
      
      const input = this.shadow.getElementById('input') as HTMLInputElement;
      const text = input.value.trim();
      if (!text) return;

      this.isLoading = true;
      const submitBtn = this.shadow.getElementById('submit-btn') as HTMLButtonElement;
      submitBtn.disabled = true;

      this.messages.push({ role: 'user', content: text });
      this.updateMessages();
      input.value = '';

      const assistantMsgIndex = this.messages.length;
      this.messages.push({ role: 'assistant', content: '' });

      try {
        const API_URL = (import.meta as any).env.PUBLIC_API_URL ?? 'http://localhost:3000/api';
        const response = await fetch(`${API_URL}/ai/chat`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${getToken()}`,
          },
          body: JSON.stringify({
            messages: this.messages.slice(0, -1),
            provider: 'openrouter',
            model: 'nvidia/llama-3.1-nemotron-70b-instruct:free',
          }),
        });

        if (!response.ok || !response.body) throw new Error('Failed');

        const reader = response.body.getReader();
        const decoder = new TextDecoder();

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          const chunk = decoder.decode(value);
          const lines = chunk.split('\n');
          for (const line of lines) {
            if (line.startsWith('data: ')) {
              try {
                const data = JSON.parse(line.slice(6));
                if (data.content) {
                  this.messages[assistantMsgIndex].content += data.content;
                  this.updateMessages();
                }
              } catch (e) {}
            }
          }
        }
      } catch (err) {
        this.messages[assistantMsgIndex].content = 'Error connecting to the AI.';
        this.updateMessages();
      } finally {
        this.isLoading = false;
        submitBtn.disabled = false;
      }
    }

    private updateMessages() {
      const container = this.shadow.getElementById('messages');
      if (!container) return;

      if (this.messages.length === 0) return;
      
      container.innerHTML = this.messages
        .map((m) => `<div class="msg ${m.role}">${m.content}</div>`)
        .join('');

      container.scrollTop = container.scrollHeight;
    }
  }

  customElements.define('chat-bot', ChatBot);
</script>
