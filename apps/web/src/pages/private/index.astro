---
import { PrivateLayout } from '@components/private/PrivateLayout';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Area Privada" description="Tu area privada con herramientas y apps exclusivas.">
  <div class="pt-20">
    <PrivateLayout client:load currentPath="/private">
      <div>
        <h1 style="font-family: var(--font-display); font-size: 1.875rem; font-weight: 700; letter-spacing: -0.025em;">
          Mis <span class="gradient-text">Apps Privadas</span>
        </h1>
        <p style="margin-top: 8px; font-size: 0.875rem; color: var(--color-text-secondary);">
          Herramientas y micro-apps exclusivas.
        </p>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; margin-top: 32px;">
          <a
            href="/private/padel-bot"
            class="group themed-card"
            style="display: block; padding: 24px; border-radius: 16px; text-decoration: none; transition: all 0.3s;"
          >
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <span style="font-size: 2rem;">🎾</span>
              <span style="display: flex; align-items: center; gap: 6px; border-radius: 9999px; padding: 4px 10px; font-size: 0.75rem; font-weight: 500; background: rgba(74, 222, 128, 0.1); color: #4ade80;">
                <span style="width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: pulse 2s infinite;"></span>
                Live
              </span>
            </div>
            <h2 class="group-hover:text-brand-500 dark:group-hover:text-brand-400" style="margin-top: 16px; font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; transition: color 0.2s;">
              Padel Bot
            </h2>
            <p style="margin-top: 8px; font-size: 0.875rem; color: var(--color-text-secondary);">
              Lanza reservas automaticas de pistas de padel configurando hora, dias y preferencias.
            </p>
            <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px;">
              <span style="border-radius: 9999px; padding: 2px 8px; font-size: 0.75rem; background: var(--color-overlay); color: var(--color-text-muted);">GitHub Actions</span>
              <span style="border-radius: 9999px; padding: 2px 8px; font-size: 0.75rem; background: var(--color-overlay); color: var(--color-text-muted);">API Dispatch</span>
            </div>
          </a>
        </div>
      </div>
    </PrivateLayout>
  </div>
</BaseLayout>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>
